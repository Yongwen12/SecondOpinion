OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

SECONDOPINION_CLAIM_MODEL=gpt-5-nano
SECONDOPINION_JUDGE_MODEL=gpt-5-nano
SECONDOPINION_ANNOTATION_MODEL=gpt-5-nano
SECONDOPINION_REASONING_EFFORT=minimal

# Optional: redirect generated data/... and reports/... artifacts outside the repo.
# SECONDOPINION_STORAGE_ROOT=C:\path\to\SecondOpinionData
# Server/API configuration
SECONDOPINION_DATABASE_URL=sqlite:///data/server/secondopinion.db
SECONDOPINION_SERVER_ARTIFACT_ROOT=data/server
SECONDOPINION_SCORING_MEMORY=data/normalized/scoring_memory_external_full_lite_v0.1.jsonl
SECONDOPINION_MEMORY_INDEX_VERSION=external-full-lite-v0.1
SECONDOPINION_SCORER_VERSION=server-hybrid-scorer-v0.1
SECONDOPINION_ENABLE_LLM_SCORER=0
SECONDOPINION_SCORER_MODEL=gpt-5-nano
# Comma-separated origins for deployed frontend, e.g. https://yongwen12.github.io
SECONDOPINION_CORS_ORIGINS=

